site_s4: COM ATOMS=5803,5344,2083,1665,2139,2204,2586,2618,2066
lig: COM ATOMS=5822,5823,5824,5825,5826,5827,5828,5829,5830,5831,5832,5833,5834,5835,5836,5837,5838,5839,5840,5841,5842
